[Unit]
Description=vLLM Qwen3-Coder-Next-FP8 Service
After=docker.service
Requires=docker.service
Conflicts=vllm-glm-4-flash.service

[Service]
Type=oneshot
RemainAfterExit=yes
User=jack

ExecStart=/home/jack/deploy/vllm/spark-vllm-docker/vllm-start-qwen3-coder-next.sh
ExecStop=/usr/bin/docker stop --time=60 vllm_node
ExecStopPost=/usr/bin/docker rm -f vllm_node

TimeoutStopSec=90

[Install]
WantedBy=multi-user.target
